# ============================================================
# ORBITA - Configuración de Variables de Entorno
# Copia este archivo como .env y ajusta los valores
# ============================================================

# --- MODO SCRAPING (opcional, gratuito si no tienes) ---
# Si tienes una cuenta gratuita de Apify, pon tu key aquí
# De lo contrario, el sistema usará scraper HTTP local gratuito
APIFY_API_KEY=

# --- NOTION (opcional, gratuito si usas SQLite) ---
# Si tienes token de Notion, los leads se guardarán ahí
# Si no, se usará SQLite local (gratuito)
NOTION_TOKEN=
NOTION_LEADS_DB=1ac85a64-4afd-42d3-9b12-2d1550d819d4

# --- LLM (opcional) ---
# Si tienes API key de Anthropic, se usará para enrichment/QA avanzado
# De lo contrario, se usarán templates deterministas gratuitos
ANTHROPIC_API_KEY=

# --- APOLLO (opcional, para enrichment de emails) ---
# Si tienes cuenta gratuita de Apollo.io (100 búsquedas/mes), pon tu key aquí
# De lo contrario, el sistema usará scraping web gratuito
APOLLO_API_KEY=KRBKk2cVa91iNKamr_Ygqw

# --- OLLAMA (opcional, para LLM local gratuito) ---
# URL de Ollama local (default: http://localhost:11434)
# OLLAMA_URL=http://localhost:11434

# --- SUPABASE (opcional) ---
# Solo si necesitas storage en la nube
# SUPABASE_ACCESS_TOKEN=

# --- CONFIGURACIÓN ---
PORT=8000
OUTPUT_DIR=outputs